# Your deployer wallet private key — export from MetaMask
# Settings → Account Details → Export Private Key
# NEVER commit this file with a real key in it
PRIVATE_KEY=your_private_key_here

# Basescan API key for contract verification (free)
# https://basescan.org/myapikey
BASESCAN_API_KEY=your_basescan_api_key_here
